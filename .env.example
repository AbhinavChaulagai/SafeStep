# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://safestep:safestep@localhost:5432/safestep

# OpenAI
OPENAI_API_KEY=

# NYC Open Data (Socrata) — free, but token raises rate limit
SOCRATA_APP_TOKEN=

# Reddit API — create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SafeStep/1.0

# News APIs
NEWS_API_KEY=
NYT_API_KEY=

# Census
CENSUS_API_KEY=

# Mapbox (used by frontend via VITE_ prefix)
VITE_MAPBOX_TOKEN=
